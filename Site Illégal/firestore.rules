// ⚠️  CE FICHIER N'EST PAS DÉPLOYÉ — Firebase utilise ../firestore.rules (racine du repo)
// Ce fichier est gardé ici uniquement comme copie de référence.
// Pour déployer les règles : npx firebase-tools deploy --only firestore:rules (depuis FratWorld/)

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return isAuthenticated() && getUserDoc().role == 'admin';
    }
    function isReferentOrAdmin() {
      return isAuthenticated() &&
             (getUserDoc().role == 'referent' || getUserDoc().role == 'admin');
    }

    // ── users ──────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isAuthenticated();
      allow create: if isAdmin();
      // Admin : tout. Utilisateur : peut mettre à jour uniquement lastSeen sur son propre doc.
      allow update: if isAdmin() ||
                       (isAuthenticated() && userId == request.auth.uid &&
                        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastSeen']));
      allow delete: if isAdmin();
    }

    // ── entries ────────────────────────────────────────────────
    function isVoteUpdate() {
      return request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['votesFor', 'votesAgainst', 'votesAbstain',
                       'votesAgainstReasons', 'updatedAt', 'status', 'deadlineReminderSent']);
    }

    match /entries/{entryId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isAdmin() ||
                       (isReferentOrAdmin() && resource.data.authorUid == request.auth.uid) ||
                       (isReferentOrAdmin() && isVoteUpdate());
      allow delete: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);

      match /history/{historyId} {
        allow read:           if isAuthenticated();
        allow create:         if isReferentOrAdmin();
        allow update, delete: if false;
      }
    }

    // ── dossiers ───────────────────────────────────────────────
    match /dossiers/{dossierId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isReferentOrAdmin();
      allow delete: if isAdmin();
    }

    // ── documents illégaux ─────────────────────────────────────
    match /documents/{docId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
    }

    // ── factions ───────────────────────────────────────────────
    match /factions/{factionId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isReferentOrAdmin();
      allow delete: if isAdmin();

      match /membres/{membreId} {
        allow read:   if isAuthenticated();
        allow create: if isReferentOrAdmin();
        allow update: if isReferentOrAdmin();
        allow delete: if isReferentOrAdmin();
      }

      match /events/{eventId} {
        allow read:   if isAuthenticated();
        allow create: if isReferentOrAdmin();
        allow update: if isReferentOrAdmin();
        allow delete: if isReferentOrAdmin();
      }
    }

    // ── communiqués ────────────────────────────────────────────
    match /communiques/{commId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── settings ───────────────────────────────────────────────
    match /settings/{settingId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── Journal d'activité ─────────────────────────────────────
    match /activityLog/{logId} {
      allow read:           if request.auth != null;
      allow create:         if request.auth != null;
      allow update, delete: if false;
    }

    // ── Délégation de vote ─────────────────────────────────────
    match /delegations/{delegatorUid} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null && delegatorUid == request.auth.uid;
      allow update: if request.auth != null && delegatorUid == request.auth.uid;
      allow delete: if request.auth != null && delegatorUid == request.auth.uid;
    }

    // ── Règlement versionné ────────────────────────────────────
    match /reglement/{sectionId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    match /reglement_history/{histId} {
      allow read:           if isAdmin();
      allow create:         if isAdmin();
      allow update, delete: if false;
    }

    // ── tasks ──────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
    }

    // ── agenda ─────────────────────────────────────────────────
    match /agenda/{eventId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
    }

    // ── relations ──────────────────────────────────────────────
    match /relations/{relationId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
    }

    // ── markers (carte interactive) ────────────────────────────
    match /markers/{markerId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
    }
  }
}
