rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return isAuthenticated() && getUserDoc().role == 'admin';
    }
    function isReferentOrAdmin() {
      return isAuthenticated() &&
             (getUserDoc().role == 'referent' || getUserDoc().role == 'admin');
    }

    // ── users ──────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── entries ────────────────────────────────────────────────
    match /entries/{entryId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);

      match /history/{historyId} {
        allow read:           if isAuthenticated();
        allow create:         if isReferentOrAdmin();
        allow update, delete: if false;
      }
    }

    // ── dossiers (création faction) ────────────────────────────
    match /dossiers/{dossierId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      // Tout référent peut voter ou modifier un dossier (vote, archivage)
      allow update: if isReferentOrAdmin();
      allow delete: if isAdmin();
    }

    // ── documents illégaux ─────────────────────────────────────
    match /documents/{docId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
    }

    // ── factions ───────────────────────────────────────────────
    match /factions/{factionId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isReferentOrAdmin();
      allow delete: if isAdmin();
    }
  }
}
