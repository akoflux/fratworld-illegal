rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function isAdmin() {
      return isAuthenticated() && getUserDoc().role == 'admin';
    }
    function isReferentOrAdmin() {
      return isAuthenticated() &&
             (getUserDoc().role == 'referent' || getUserDoc().role == 'admin');
    }

    // ── users ──────────────────────────────────────────────────
    match /users/{userId} {
      allow read:   if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── entries ────────────────────────────────────────────────
    function isVoteUpdate() {
      // Seuls les champs de vote peuvent être modifiés par n'importe quel référent
      return request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['votesFor', 'votesAgainst', 'votesAbstain',
                       'votesAgainstReasons', 'updatedAt', 'status', 'deadlineReminderSent']);
    }

    match /entries/{entryId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isAdmin() ||
                       (isReferentOrAdmin() && resource.data.authorUid == request.auth.uid) ||
                       (isReferentOrAdmin() && isVoteUpdate());
      allow delete: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);

      match /history/{historyId} {
        allow read:           if isAuthenticated();
        allow create:         if isReferentOrAdmin();
        allow update, delete: if false;
      }
    }

    // ── dossiers ───────────────────────────────────────────────
    match /dossiers/{dossierId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isReferentOrAdmin();
      allow delete: if isAdmin();
    }

    // ── documents illégaux ─────────────────────────────────────
    match /documents/{docId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
    }

    // ── factions ───────────────────────────────────────────────
    match /factions/{factionId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isReferentOrAdmin();
      allow delete: if isAdmin();

      match /membres/{membreId} {
        allow read:   if isAuthenticated();
        allow create: if isReferentOrAdmin();
        allow update: if isReferentOrAdmin();
        allow delete: if isReferentOrAdmin();
      }
    }

    // ── communiqués ────────────────────────────────────────────
    match /communiques/{commId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── settings ───────────────────────────────────────────────
    match /settings/{settingId} {
      allow read:  if isAuthenticated();
      allow write: if isAdmin();
    }

    // ── tasks ──────────────────────────────────────────────────
    match /tasks/{taskId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
    }

    // ── agenda ─────────────────────────────────────────────────
    match /agenda/{eventId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
    }

    // ── relations ──────────────────────────────────────────────
    match /relations/{relationId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
    }

    // ── markers (carte interactive) ────────────────────────────
    match /markers/{markerId} {
      allow read:   if isAuthenticated();
      allow create: if isReferentOrAdmin();
      allow update: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
      allow delete: if isAdmin() ||
                       (isReferentOrAdmin() &&
                        resource.data.authorUid == request.auth.uid);
    }
  }
}
